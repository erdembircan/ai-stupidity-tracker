#!/usr/bin/env bash
set -euo pipefail

input=$(cat)
model=$(echo "$input" | jq -r '.model // empty')
[[ -z "$model" ]] && exit 0

rankings=$(ast --json 2>/dev/null) || exit 0

# Strip context suffix like [1m]
base_model="${model%%\[*}"
current_rank=$(echo "$rankings" | jq -r --arg m "$base_model" '[.rankings[] | select(.name | contains($m))][0].rank // empty')
current_score=$(echo "$rankings" | jq -r --arg m "$base_model" '[.rankings[] | select(.name | contains($m))][0].score // empty')

best_coder=$(echo "$rankings" | jq -r '.bestCoder.name // empty')
best_coder_score=$(echo "$rankings" | jq -r '.bestCoder.score // empty')

if [[ -z "$current_rank" ]]; then
  jq -n --arg bc "$best_coder" --arg bcs "$best_coder_score" \
    '{"systemMessage": "⚠ AI Stupidity Index: Best coder is \($bc) (score \($bcs)). Your model was not found in rankings."}'
elif [[ -n "$best_coder" && "$base_model" != *"$best_coder"* && "$best_coder" != *"$base_model"* ]]; then
  jq -n --arg m "$base_model" --arg cs "$current_score" \
    --arg bc "$best_coder" --arg bcs "$best_coder_score" \
    '{"systemMessage": "⚠ AI Stupidity Index: Best coder is \($bc) (score \($bcs)) vs your \($m) (score \($cs)). Consider /model to switch."}'
fi
