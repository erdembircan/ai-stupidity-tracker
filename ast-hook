#!/usr/bin/env bash
set -euo pipefail

input=$(cat)
model=$(echo "$input" | jq -r '.model // empty')
[[ -z "$model" ]] && exit 0

rankings=$(ast --json 2>/dev/null) || exit 0

# Strip context suffix like [1m]
base_model="${model%%\[*}"
current_rank=$(echo "$rankings" | jq -r --arg m "$base_model" '[.rankings[] | select(.name | contains($m))][0].rank // empty')
current_score=$(echo "$rankings" | jq -r --arg m "$base_model" '[.rankings[] | select(.name | contains($m))][0].score // empty')

best_name=$(echo "$rankings" | jq -r '.rankings[0].name')
best_rank=$(echo "$rankings" | jq -r '.rankings[0].rank')
best_score=$(echo "$rankings" | jq -r '.rankings[0].score')

if [[ -z "$current_rank" ]]; then
  jq -n --arg b "$best_name" --arg br "$best_rank" --arg bs "$best_score" \
    '{"systemMessage": "⚠ AI Stupidity Index: Top Claude model is \($b) (rank #\($br), score \($bs)). Your model was not found in rankings."}'
elif [[ "$current_rank" -gt "$best_rank" ]]; then
  jq -n --arg m "$base_model" --arg cr "$current_rank" --arg cs "$current_score" \
    --arg b "$best_name" --arg br "$best_rank" --arg bs "$best_score" \
    '{"systemMessage": "⚠ AI Stupidity Index: \($b) is ranked #\($br) (score \($bs)) vs your \($m) at #\($cr) (score \($cs)). Consider /model to switch."}'
fi
