#!/usr/bin/env bash
set -euo pipefail

# ── Constants ───────────────────────────────────────
readonly VERSION="1.0.0"
readonly BASE_URL="https://aistupidlevel.info"
readonly DASHBOARD_URL="${BASE_URL}/dashboard/cached?period=latest&sortBy=combined&analyticsPeriod=latest"
readonly GLOBAL_INDEX_URL="${BASE_URL}/dashboard/global-index"
readonly BOX_WIDTH=54
readonly MIN_TERM_WIDTH=$((BOX_WIDTH + 2))
NARROW_TERM=false
if [[ ! -t 1 ]] || [[ -n "${NO_COLOR:-}" ]]; then
  NARROW_TERM=true
elif TERM_WIDTH=$(tput cols 2>/dev/null); then
  if ((TERM_WIDTH < MIN_TERM_WIDTH)); then
    NARROW_TERM=true
  fi
fi
readonly NARROW_TERM

# ── Dependency Check ────────────────────────────────
if ! command -v jq &>/dev/null; then
  echo "Error: jq is required but not installed."
  echo "Install it via: brew install jq"
  exit 1
fi

if ! command -v curl &>/dev/null; then
  echo "Error: curl is required but not installed."
  exit 1
fi

# ── Colors ──────────────────────────────────────────
if [[ -n "${NO_COLOR:-}" ]]; then
  RST="" BOLD="" DIM="" RED="" GREEN="" YELLOW="" CYAN="" GRAY="" WHITE=""
else
  RST=$'\033[0m'
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  RED=$'\033[31m'
  GREEN=$'\033[32m'
  YELLOW=$'\033[33m'
  CYAN=$'\033[36m'
  GRAY=$'\033[90m'
  WHITE=$'\033[97m'
fi
readonly RST BOLD DIM RED GREEN YELLOW CYAN GRAY WHITE

# ── Symbols ─────────────────────────────────────────
readonly SYM_CHECK='✓'
readonly SYM_CROSS='✗'
readonly SYM_WARN='⚠'
readonly SYM_DIAMOND='◆'
readonly SYM_ARROW='→'
readonly SYM_BULLET='•'
readonly SYM_UP='↑'
readonly SYM_DOWN='↓'

# ── Box Drawing Helpers ─────────────────────────────
# Right border column (2 indent + BOX_WIDTH)
readonly RIGHT_COL=$((BOX_WIDTH + 2))

box_top() {
  local title="$1"
  local title_len=${#title}
  # ╭── (3) + space (1) + title + space (1) + dashes + ╮ (1) = BOX_WIDTH
  local dashes=$((BOX_WIDTH - title_len - 6))
  if ((dashes < 1)); then dashes=1; fi
  if [[ "$NARROW_TERM" == true ]]; then
    printf "  ${DIM}╭──${RST} ${BOLD}%s${RST} ${DIM}%s${RST}\n" "$title" "$(printf '%*s' "$dashes" '' | tr ' ' '─')"
  else
    printf "  ${DIM}╭──${RST} ${BOLD}%s${RST} ${DIM}%s╮${RST}\n" "$title" "$(printf '%*s' "$dashes" '' | tr ' ' '─')"
  fi
}

box_row() {
  local content="$1"
  if [[ "$NARROW_TERM" == true ]]; then
    printf "  ${DIM}│${RST} %s${RST}\n" "$content"
  else
    # Use cursor positioning to place right border at fixed column
    # This avoids all Unicode display-width issues
    printf "  ${DIM}│${RST} %s${RST}\033[${RIGHT_COL}G${DIM}│${RST}\n" "$content"
  fi
}

box_bottom() {
  # ╰ (1) + dashes + ╯ (1) = BOX_WIDTH
  if [[ "$NARROW_TERM" == true ]]; then
    printf "  ${DIM}╰%s${RST}\n" "$(printf '%*s' $((BOX_WIDTH - 2)) '' | tr ' ' '─')"
  else
    printf "  ${DIM}╰%s╯${RST}\n" "$(printf '%*s' $((BOX_WIDTH - 2)) '' | tr ' ' '─')"
  fi
}

box_empty() {
  box_row "${GRAY}${1}${RST}"
}

# ── Dot Leader Helper ───────────────────────────────
dot_row() {
  local label="$1" value="$2"
  local label_stripped
  label_stripped=$(printf '%s' "$label" | sed $'s/\033\\[[0-9;]*m//g')
  local value_stripped
  value_stripped=$(printf '%s' "$value" | sed $'s/\033\\[[0-9;]*m//g')
  local total_content=$((${#label_stripped} + ${#value_stripped}))
  # 1 (│) + 1 (space) + label + dots + value + 1 (space) + 1 (│) = BOX_WIDTH
  local dots=$((BOX_WIDTH - total_content - 5))
  if ((dots < 2)); then dots=2; fi
  local dot_str
  dot_str=$(printf '%*s' "$dots" '' | tr ' ' '·')
  box_row "${label} ${DIM}${dot_str}${RST} ${value}"
}

# ── Status Color Helper ─────────────────────────────
status_color() {
  local status="$1"
  case "$status" in
  stable | good) printf '%s' "${GREEN}" ;;
  volatile | warning | minor) printf '%s' "${YELLOW}" ;;
  degraded | critical | unreliable | major) printf '%s' "${RED}" ;;
  recovering) printf '%s' "${CYAN}" ;;
  *) printf '%s' "${RST}" ;;
  esac
}

status_label() {
  local status="$1"
  case "$status" in
  stable | good) echo "STABLE" ;;
  volatile | warning) echo "VOLATILE" ;;
  degraded | critical) echo "DEGRADED" ;;
  recovering) echo "RECOVERING" ;;
  *) echo "$status" | tr '[:lower:]' '[:upper:]' ;;
  esac
}

# ── Spinner ─────────────────────────────────────────
SPINNER_PID=""

spinner_start() {
  local msg="${1:-Fetching data}"
  local frames=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
  (
    local i=0
    while true; do
      printf '\r%s' "  ${DIM}${frames[$i]} ${msg}${RST}" >&2
      i=$(((i + 1) % ${#frames[@]}))
      sleep 0.08
    done
  ) &
  SPINNER_PID=$!
}

spinner_stop() {
  if [[ -n "$SPINNER_PID" ]]; then
    kill "$SPINNER_PID" 2>/dev/null || true
    wait "$SPINNER_PID" 2>/dev/null || true
    SPINNER_PID=""
    if [[ "$NARROW_TERM" == true ]]; then
      printf '\r%s' "$(printf '%*s' 40 '')" >&2
      printf '\r' >&2
    else
      printf "\r\033[2K" >&2
    fi
  fi
}

trap spinner_stop EXIT

# ── Fetch Data ──────────────────────────────────────
fetch_data() {
  local url="$1"
  local response
  response=$(curl -sf --max-time 10 "$url" 2>/dev/null)
  if [[ -z "$response" ]]; then
    spinner_stop
    printf '%s\n' "  ${RED}${SYM_CROSS} Failed to fetch data from API${RST}"
    exit 1
  fi
  printf '%s\n' "$response"
}

# ── JSON Output ─────────────────────────────────────
output_json() {
  local dashboard global_index
  dashboard=$(fetch_data "$DASHBOARD_URL")
  global_index=$(fetch_data "$GLOBAL_INDEX_URL")

  local now
  now=$(date +"%Y-%m-%d %H:%M")

  local reco
  reco=$(echo "$dashboard" | jq '.data.recommendations')

  # Build the entire JSON in a single jq call
  jq -n \
    --arg version "$VERSION" \
    --arg timestamp "$now" \
    --argjson global_index "$global_index" \
    --argjson dashboard "$dashboard" \
    --argjson reco "$reco" \
    '
    # Global index
    {
      version: $version,
      timestamp: $timestamp,
      globalIndex: {
        score: $global_index.data.current.globalScore,
        trend: $global_index.data.trend,
        performingWell: $global_index.data.performingWell,
        totalModels: $global_index.data.totalModels
      },

      # Claude rankings
      claudeRankings: [
        $dashboard.data.modelScores | to_entries[] |
        select(.value.provider == "anthropic") |
        {
          rank: (.key + 1),
          name: .value.name,
          score: .value.currentScore,
          status: (
            if .value.status == "good" then "stable"
            elif .value.status == "warning" then "volatile"
            else .value.status
            end
          )
        }
      ],

      # Best for categories
      bestFor: {
        code: (if $reco.bestForCode.vendor == "anthropic"
          then {name: $reco.bestForCode.name, score: $reco.bestForCode.score}
          else null end),
        reliable: (if $reco.mostReliable.vendor == "anthropic"
          then {name: $reco.mostReliable.name, score: $reco.mostReliable.score}
          else null end),
        fastest: (if $reco.fastestResponse.vendor == "anthropic"
          then {name: $reco.fastestResponse.name, score: $reco.fastestResponse.score}
          else null end),
        value: (if ($reco.bestValue // {}).vendor == "anthropic"
          then {name: $reco.bestValue.name, score: $reco.bestValue.score}
          else null end)
      },

      # Alerts
      alerts: {
        avoid: [
          ($reco.avoidNow // [])[] |
          select(.vendor == "anthropic" or .provider == "anthropic") |
          .name
        ],
        degradations: [
          $dashboard.data.degradations[] |
          select(.provider == "anthropic") |
          {
            model: .modelName,
            severity: .severity,
            type: .type,
            message: .message
          }
        ]
      },

      # Provider trust
      providerTrust: (
        [$dashboard.data.providerReliability[] | select(.provider == "anthropic")] |
        if length > 0 then
          .[0] | {
            score: .trustScore,
            trend: .trend,
            incidentsPerMonth: .incidentsPerMonth
          }
        else null end
      ),

      # Drift incidents
      driftIncidents: [
        ($dashboard.data.driftIncidents // []) |
        [.[] | select(.provider == "anthropic" or (.modelName | test("claude"; "i")))] |
        group_by(.modelName)[] |
        {
          model: .[0].modelName,
          severity: .[0].severity,
          count: length
        }
      ]
    }
    '
}

# ── Render ─────────────────────────────────────────
render() {
  local dashboard="$1" global_index="$2" last_updated="$3"
  local prev_ranks="${4:-}"

  # ── Extract all global index data in one call ───
  local g_score g_trend g_performing g_total
  read -r g_score g_trend g_performing g_total < <(
    printf '%s\n' "$global_index" | jq -r '[.data.current.globalScore, .data.trend, .data.performingWell, .data.totalModels] | @tsv'
  )

  # ── Extract all dashboard data in one call ──────
  local d
  d=$(printf '%s\n' "$dashboard" | jq '
    (.data.modelScores | to_entries | [.[] | select(.value.provider == "anthropic")]) as $claude |
    (.data.recommendations) as $reco |
    {
      goodModels: ([.data.modelScores[] | select(.status == "good") | .name] | join(", ")),
      claudeModels: [$claude[] | {rank: (.key + 1), name: .value.name, score: .value.currentScore, status: .value.status}],
      claudeCount: ($claude | length),
      maxNameLen: ([$claude[].value.name | length] | max // 0),
      bestFor: [
        (if $reco.bestForCode.vendor == "anthropic"
         then {label: "BEST FOR CODE", pad: 6, name: $reco.bestForCode.name, score: $reco.bestForCode.score} else empty end),
        (if $reco.mostReliable.vendor == "anthropic"
         then {label: "MOST RELIABLE", pad: 5, name: $reco.mostReliable.name, score: $reco.mostReliable.score} else empty end),
        (if $reco.fastestResponse.vendor == "anthropic"
         then {label: "FASTEST RESPONSE", pad: 2, name: $reco.fastestResponse.name, score: $reco.fastestResponse.score} else empty end),
        (if ($reco.bestValue // {}).vendor == "anthropic"
         then {label: "BEST VALUE", pad: 8, name: $reco.bestValue.name, score: $reco.bestValue.score} else empty end)
      ],
      avoidNow: [($reco.avoidNow // [])[] | select(.vendor == "anthropic" or .provider == "anthropic") | .name],
      degradations: [.data.degradations[] | select(.provider == "anthropic") | {name: .modelName, severity, type, message}],
      providerTrust: (
        [.data.providerReliability[] | select(.provider == "anthropic")] |
        if length > 0 then .[0] | {score: .trustScore, trend, incidents: .incidentsPerMonth}
        else null end
      ),
      driftIncidents: [
        (.data.driftIncidents // []) |
        [.[] | select(.provider == "anthropic" or (.modelName | test("claude"; "i")))] |
        group_by(.modelName)[] |
        {name: .[0].modelName, severity: (.[0].severity // "unknown"), count: length}
      ]
    }
  ')

  # ── Read all scalar fields from extracted data ──
  local claude_count max_name_len best_count avoid_count deg_count drift_count
  read -r claude_count max_name_len best_count avoid_count deg_count drift_count < <(
    printf '%s\n' "$d" | jq -r '[.claudeCount, .maxNameLen, (.bestFor | length), (.avoidNow | length), (.degradations | length), (.driftIncidents | length)] | @tsv'
  )
  local good_models
  good_models=$(printf '%s\n' "$d" | jq -r '.goodModels')

  # ── Header ──────────────────────────────────────
  printf "\n"
  printf '%s\n' "  ${BOLD}${CYAN}${SYM_DIAMOND} AST${RST}  ${DIM}v${VERSION} ${GRAY}${SYM_BULLET} ${last_updated}${RST}"
  printf "\n"

  # ── Global Index ────────────────────────────────
  local trend_color
  trend_color=$(status_color "$g_trend")

  box_top "Global AI Index"
  dot_row "Score" "${BOLD}${trend_color}${g_score}${RST}/100 ${trend_color}$(status_label "$g_trend")${RST}"
  dot_row "Performing well" "${BOLD}${g_performing}${RST}/${g_total}"
  if [[ -n "$good_models" ]]; then
    local max_len=44
    if ((${#good_models} > max_len)); then
      good_models="${good_models:0:$((max_len - 3))}..."
    fi
    box_row "  ${GREEN}${SYM_ARROW}${RST} ${DIM}${good_models}${RST}"
  fi
  box_bottom
  printf "\n"

  # ── Claude Rankings ─────────────────────────────
  box_top "Claude Rankings"
  if ((claude_count == 0)); then
    box_empty "No Claude models found in rankings"
  else
    printf '%s\n' "$d" | jq -r '.claudeModels[] | "\(.rank)|\(.name)|\(.score)|\(.status)"' | while IFS='|' read -r rank name score status; do
      local sc
      sc=$(status_color "$status")
      local sl
      sl=$(status_label "$status")
      # Rank change indicator — fixed 4-char column (watch mode only)
      local change_col="    "
      if [[ -n "$prev_ranks" ]]; then
        local prev_rank
        prev_rank=$(printf '%s\n' "$prev_ranks" | jq -r --arg n "$name" '.[$n] // empty')
        if [[ -n "$prev_rank" ]] && ((prev_rank != rank)); then
          local arrow_text
          if ((rank < prev_rank)); then
            arrow_text="${GREEN}${SYM_UP}${prev_rank}${RST}"
          else
            arrow_text="${RED}${SYM_DOWN}${prev_rank}${RST}"
          fi
          # Pad visible chars to 4: arrow(1) + digits + trailing spaces
          local visible_len=$((1 + ${#prev_rank}))
          local pad=$((4 - visible_len))
          change_col="${arrow_text}$(printf '%*s' "$pad" '')"
        fi
      fi
      # Pad rank, name, score for alignment
      local rank_str
      rank_str=$(printf '#%-2s' "$rank")
      local name_str
      name_str=$(printf "%-${max_name_len}s" "$name")
      local score_str
      score_str=$(printf '%-3s' "$score")
      local sym
      case "$status" in
      good | stable) sym="$SYM_CHECK" ;;
      volatile | warning) sym="$SYM_WARN" ;;
      *) sym="$SYM_CROSS" ;;
      esac
      box_row "${BOLD}${WHITE}${rank_str}${RST} ${change_col}${name_str} ${BOLD}${score_str}${RST} ${sc}${sym} ${sl}${RST}"
    done
  fi
  box_bottom
  printf "\n"

  # ── Best For Categories ─────────────────────────
  box_top "Best For Categories"
  if ((best_count == 0)); then
    box_empty "No Claude model in any best-for category"
  else
    printf '%s\n' "$d" | jq -r '.bestFor[] | "\(.label)|\(.pad)|\(.name)|\(.score)"' | while IFS='|' read -r label pad_len name score; do
      local pad
      pad=$(printf '%*s' "$pad_len" '')
      box_row "${GREEN}${SYM_CHECK} ${label}${RST}${pad}${name} (${BOLD}${score}${RST})"
    done
  fi
  box_bottom
  printf "\n"

  # ── Alerts (Unreliable + Degradations) ──────────
  box_top "Alerts"
  if ((avoid_count == 0)) && ((deg_count == 0)); then
    box_row "${GREEN}${SYM_CHECK} No active alerts for Claude models${RST}"
  else
    if ((avoid_count > 0)); then
      printf '%s\n' "$d" | jq -r '.avoidNow[]' | while read -r name; do
        box_row "${RED}${SYM_CROSS} AVOID${RST}  ${name}"
      done
    fi

    if ((deg_count > 0)); then
      printf '%s\n' "$d" | jq -r '.degradations[] | "\(.name)|\(.severity)|\(.type)|\(.message)"' | while IFS='|' read -r name severity dtype message; do
        # Clean message: strip emoji, leading label, and truncate
        local clean_msg
        clean_msg=$(printf '%s' "$message" | LC_ALL=C tr -cd '\11\12\40-\176' | sed 's/^ *//; s/^[A-Z_ ]*: //')
        if ((${#clean_msg} > BOX_WIDTH - 6)); then
          clean_msg="${clean_msg:0:$((BOX_WIDTH - 9))}..."
        fi
        local sc
        sc=$(status_color "$severity")
        local label
        case "$dtype" in
        unstable_performance) label="UNSTABLE" ;;
        critical_failure) label="CRITICAL" ;;
        performance_variance) label="VARIANCE" ;;
        poor_performance) label="POOR" ;;
        *) label=$(printf '%s' "$severity" | tr '[:lower:]' '[:upper:]') ;;
        esac
        box_row "${sc}${SYM_WARN} ${label}${RST}  ${name}"
        box_row "  ${DIM}${clean_msg}${RST}"
      done
    fi
  fi
  box_bottom
  printf "\n"

  # ── Anthropic Provider Trust ────────────────────
  local trust_tsv
  trust_tsv=$(printf '%s\n' "$d" | jq -r 'if .providerTrust then [.providerTrust.score, .providerTrust.trend, .providerTrust.incidents] | @tsv else empty end')
  if [[ -n "$trust_tsv" ]]; then
    local trust_score trust_trend incidents
    read -r trust_score trust_trend incidents <<<"$trust_tsv"
    local tc
    tc=$(status_color "$trust_trend")

    box_top "Anthropic Provider Trust"
    dot_row "Trust Score" "${BOLD}${tc}${trust_score}${RST}/100"
    dot_row "Trend" "${tc}${trust_trend}${RST}"
    dot_row "Incidents/month" "${YELLOW}${incidents}${RST}"
    box_bottom
    printf "\n"
  fi

  # ── Drift Incidents ─────────────────────────────
  if ((drift_count > 0)); then
    box_top "Drift Incidents"
    printf '%s\n' "$d" | jq -r '.driftIncidents[] | "\(.name)|\(.severity)|\(.count)"' | while IFS='|' read -r name severity count; do
      local sc
      sc=$(status_color "$severity")
      local count_str=""
      if ((count > 1)); then
        count_str=" ${DIM}(${count}x)${RST}"
      fi
      box_row "${sc}${SYM_WARN}${RST} ${name}${count_str}"
    done
    box_bottom
    printf "\n"
  fi
}

# ── Main ────────────────────────────────────────────
main() {
  local json_mode=false
  local watch_mode=false
  local watch_interval=60
  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      printf '%s\n' "  ${BOLD}${CYAN}${SYM_DIAMOND} AST${RST}  ${DIM}v${VERSION}${RST} — AI Stupidity Tracker"
      printf '\n'
      printf '%s\n' "  ${BOLD}Usage:${RST}  ast [options]"
      printf '\n'
      printf '%s\n' "  ${BOLD}Options:${RST}"
      printf '%s\n' "    --json              Machine-readable JSON output"
      printf '%s\n' "    --watch[=SECONDS]   Live dashboard, refreshes every N seconds (default: 60)"
      printf '%s\n' "    -h, --help          Show this help message"
      printf '\n'
      printf '%s\n' "  ${BOLD}Environment:${RST}"
      printf '%s\n' "    NO_COLOR=1          Disable colors and box-drawing right borders"
      exit 0
      ;;
    --json) json_mode=true ;;
    --watch=*)
      watch_mode=true
      watch_interval="${1#--watch=}"
      if ! [[ "$watch_interval" =~ ^[0-9]+$ ]]; then
        printf "  ${RED}${SYM_CROSS} Invalid watch interval: %s (must be a number)${RST}\n" "$watch_interval"
        exit 1
      fi
      ;;
    --watch)
      watch_mode=true
      if [[ -n "${2:-}" && "$2" =~ ^[0-9]+$ ]]; then
        watch_interval="$2"
        shift
      fi
      ;;
    -*)
      printf "  ${RED}${SYM_CROSS} Unknown option: %s${RST}\n" "$1"
      printf "  Usage: ast [--json] [--watch[=SECONDS]] [--help]\n"
      exit 1
      ;;
    *)
      printf "  ${RED}${SYM_CROSS} Unexpected argument: %s${RST}\n" "$1"
      printf "  Usage: ast [--json] [--watch[=SECONDS]] [--help]\n"
      exit 1
      ;;
    esac
    shift
  done

  if [[ "$json_mode" == true ]]; then
    output_json
    return
  fi

  if [[ "$watch_mode" == true ]]; then
    watch_loop "$watch_interval"
    return
  fi

  # One-shot mode
  spinner_start "Fetching Claude status"
  local dashboard global_index
  dashboard=$(fetch_data "$DASHBOARD_URL")
  global_index=$(fetch_data "$GLOBAL_INDEX_URL")
  spinner_stop

  local now
  now=$(date +"%Y-%m-%d %H:%M")

  render "$dashboard" "$global_index" "$now"
}

# ── Watch Loop ─────────────────────────────────────
watch_loop() {
  local WATCH_INTERVAL="${1:-60}"
  local first_run=true
  local prev_ranks="{}"

  trap 'exit 0' INT TERM

  while true; do
    if [[ "$first_run" == true ]]; then
      # First run: show spinner since there's nothing on screen yet
      spinner_start "Fetching Claude status"
    fi

    local dashboard global_index
    dashboard=$(fetch_data "$DASHBOARD_URL")
    global_index=$(fetch_data "$GLOBAL_INDEX_URL")

    if [[ "$first_run" == true ]]; then
      spinner_stop
      first_run=false
    fi

    local now
    now=$(date +"%Y-%m-%d %H:%M")

    # Extract current Claude rankings as {name: rank} map
    local curr_ranks
    curr_ranks=$(echo "$dashboard" | jq '
      [.data.modelScores | to_entries[] |
       select(.value.provider == "anthropic")] |
      map({(.value.name): (.key + 1)}) | add // {}
    ')

    # Capture output, then clear and print in one shot to reduce flicker
    local output
    output=$(render "$dashboard" "$global_index" "$now" "$prev_ranks")
    printf '\033[2J\033[H%s\n' "$output"

    printf '%s\n' "  ${DIM}Last updated ${now} ${GRAY}${SYM_BULLET}${RST} ${DIM}refreshing every ${WATCH_INTERVAL}s ${GRAY}${SYM_BULLET}${RST} ${DIM}Ctrl+C to exit${RST}"

    prev_ranks="$curr_ranks"

    sleep "$WATCH_INTERVAL"
  done
}

main "$@"
