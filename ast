#!/usr/bin/env bash
set -euo pipefail

# ── Constants ───────────────────────────────────────
readonly VERSION="1.0.5"
readonly BASE_URL="https://aistupidlevel.info"
readonly DASHBOARD_URL="${BASE_URL}/dashboard/cached?period=latest&sortBy=combined&analyticsPeriod=latest"
readonly GLOBAL_INDEX_URL="${BASE_URL}/dashboard/global-index"
readonly HISTORY_URL="${BASE_URL}/dashboard/history"
readonly BOX_WIDTH=54
readonly MIN_TERM_WIDTH=$((BOX_WIDTH + 2))
NARROW_TERM=false
if [[ ! -t 1 ]] || [[ -n "${NO_COLOR:-}" ]]; then
  NARROW_TERM=true
elif TERM_WIDTH=$(tput cols 2>/dev/null); then
  if ((TERM_WIDTH < MIN_TERM_WIDTH)); then
    NARROW_TERM=true
  fi
fi
readonly NARROW_TERM

# ── Dependency Check ────────────────────────────────
if ! command -v jq &>/dev/null; then
  echo "Error: jq is required but not installed."
  echo "Install it via: brew install jq"
  exit 1
fi

if ! command -v curl &>/dev/null; then
  echo "Error: curl is required but not installed."
  exit 1
fi

# ── Colors ──────────────────────────────────────────
if [[ -n "${NO_COLOR:-}" ]]; then
  RST="" BOLD="" DIM="" RED="" GREEN="" YELLOW="" CYAN="" GRAY="" WHITE=""
else
  RST=$'\033[0m'
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  RED=$'\033[31m'
  GREEN=$'\033[32m'
  YELLOW=$'\033[33m'
  CYAN=$'\033[36m'
  GRAY=$'\033[90m'
  WHITE=$'\033[97m'
fi
readonly RST BOLD DIM RED GREEN YELLOW CYAN GRAY WHITE

# ── Symbols ─────────────────────────────────────────
readonly SYM_CHECK='✓'
readonly SYM_CROSS='✗'
readonly SYM_WARN='⚠'
readonly SYM_DIAMOND='◆'
readonly SYM_ARROW='→'
readonly SYM_BULLET='•'
readonly SYM_UP='↑'
readonly SYM_DOWN='↓'

# ── Box Drawing Helpers ─────────────────────────────
# Right border column (2 indent + BOX_WIDTH)
readonly RIGHT_COL=$((BOX_WIDTH + 2))

box_top() {
  local title="$1"
  local title_len=${#title}
  # ╭── (3) + space (1) + title + space (1) + dashes + ╮ (1) = BOX_WIDTH
  local dashes=$((BOX_WIDTH - title_len - 6))
  if ((dashes < 1)); then dashes=1; fi
  if [[ "$NARROW_TERM" == true ]]; then
    printf "  ${DIM}╭──${RST} ${BOLD}%s${RST} ${DIM}%s${RST}\n" "$title" "$(printf '%*s' "$dashes" '' | tr ' ' '─')"
  else
    printf "  ${DIM}╭──${RST} ${BOLD}%s${RST} ${DIM}%s╮${RST}\n" "$title" "$(printf '%*s' "$dashes" '' | tr ' ' '─')"
  fi
}

box_row() {
  local content="$1"
  if [[ "$NARROW_TERM" == true ]]; then
    printf "  ${DIM}│${RST} %s${RST}\n" "$content"
  else
    # Use cursor positioning to place right border at fixed column
    # This avoids all Unicode display-width issues
    printf "  ${DIM}│${RST} %s${RST}\033[${RIGHT_COL}G${DIM}│${RST}\n" "$content"
  fi
}

box_bottom() {
  # ╰ (1) + dashes + ╯ (1) = BOX_WIDTH
  if [[ "$NARROW_TERM" == true ]]; then
    printf "  ${DIM}╰%s${RST}\n" "$(printf '%*s' $((BOX_WIDTH - 2)) '' | tr ' ' '─')"
  else
    printf "  ${DIM}╰%s╯${RST}\n" "$(printf '%*s' $((BOX_WIDTH - 2)) '' | tr ' ' '─')"
  fi
}

box_empty() {
  box_row "${GRAY}${1}${RST}"
}

# ── Dot Leader Helper ───────────────────────────────
dot_row() {
  local label="$1" value="$2"
  local label_stripped
  label_stripped=$(printf '%s' "$label" | sed $'s/\033\\[[0-9;]*m//g')
  local value_stripped
  value_stripped=$(printf '%s' "$value" | sed $'s/\033\\[[0-9;]*m//g')
  local total_content=$((${#label_stripped} + ${#value_stripped}))
  # 1 (│) + 1 (space) + label + dots + value + 1 (space) + 1 (│) = BOX_WIDTH
  local dots=$((BOX_WIDTH - total_content - 5))
  if ((dots < 2)); then dots=2; fi
  local dot_str
  dot_str=$(printf '%*s' "$dots" '' | tr ' ' '·')
  box_row "${label} ${DIM}${dot_str}${RST} ${value}"
}

# ── Status Color Helper ─────────────────────────────
status_color() {
  local status="$1"
  case "$status" in
  stable | good) printf '%s' "${GREEN}" ;;
  volatile | warning | minor) printf '%s' "${YELLOW}" ;;
  degraded | critical | unreliable | major) printf '%s' "${RED}" ;;
  recovering) printf '%s' "${CYAN}" ;;
  *) printf '%s' "${RST}" ;;
  esac
}

status_label() {
  local status="$1"
  case "$status" in
  stable | good) echo "STABLE" ;;
  volatile | warning) echo "VOLATILE" ;;
  degraded | critical) echo "DEGRADED" ;;
  recovering) echo "RECOVERING" ;;
  *) echo "$status" | tr '[:lower:]' '[:upper:]' ;;
  esac
}

# ── Spinner ─────────────────────────────────────────
SPINNER_PID=""

spinner_start() {
  local msg="${1:-Fetching data}"
  local frames=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)
  (
    local i=0
    while true; do
      printf '\r%s' "  ${DIM}${frames[$i]} ${msg}${RST}" >&2
      i=$(((i + 1) % ${#frames[@]}))
      sleep 0.08
    done
  ) &
  SPINNER_PID=$!
}

spinner_stop() {
  if [[ -n "$SPINNER_PID" ]]; then
    kill "$SPINNER_PID" 2>/dev/null || true
    wait "$SPINNER_PID" 2>/dev/null || true
    SPINNER_PID=""
    if [[ "$NARROW_TERM" == true ]]; then
      printf '\r%s' "$(printf '%*s' 40 '')" >&2
      printf '\r' >&2
    else
      printf "\r\033[2K" >&2
    fi
  fi
}

trap spinner_stop EXIT

# ── Coding Score Calculation ───────────────────────
# Uses the full scoring formula from aistupidmeter-web:
# 1. Each axis raised to power 1.6
# 2. Weighted sum (correctness 40%, complexity 20%, codeQuality 15%,
#    efficiency 5%, stability 10%, edgeCases 3%, debugging 3%, format 2%, safety 2%)
# 3. Professor curve: (base/100)^1.3 * 100
# 4. Quality gate penalties
calc_coding_score() {
  local corr="$1" cmplx="$2" cq="$3" eff="$4" stab="$5" edge="$6" dbg="$7" fmt="$8" safe="$9"
  awk -v corr="$corr" -v cmplx="$cmplx" -v cq="$cq" -v eff="$eff" \
    -v stab="$stab" -v edge="$edge" -v dbg="$dbg" -v fmt="$fmt" -v safe="$safe" '
    function pw(base, ex) {
      if (base <= 0) return 0
      if (base == 1) return 1
      return exp(log(base) * ex)
    }
    BEGIN {
      w = pw(corr,1.6)*0.40 + pw(cmplx,1.6)*0.20 + pw(cq,1.6)*0.15 + \
          pw(eff,1.6)*0.05 + pw(stab,1.6)*0.10 + pw(edge,1.6)*0.03 + \
          pw(dbg,1.6)*0.03 + pw(fmt,1.6)*0.02 + pw(safe,1.6)*0.02
      base = w * 100
      curved = pw(base/100, 1.3) * 100
      pen = 0
      if (corr < 0.90) pen -= 8
      if (corr < 0.70) pen -= 10
      if (corr < 0.50) pen -= 15
      if (cq < 0.60) pen -= 8
      if (cq < 0.40) pen -= 15
      if (cmplx < 0.30) pen -= 12
      printf "%.1f", curved + pen
    }'
}

fetch_coding_scores() {
  local dashboard="$1"
  local tmpdir
  tmpdir=$(mktemp -d)

  # Get model IDs for the provider
  local model_ids
  model_ids=$(printf '%s\n' "$dashboard" | jq -r \
    --arg provider "$PROVIDER" \
    '[.data.modelScores[] | select(.provider == $provider) | .id] | .[]')

  # Fetch history for each model in parallel
  local pids=()
  for id in $model_ids; do
    curl -sf --max-time 10 "${HISTORY_URL}/${id}?period=latest&sortBy=combined" \
      >"${tmpdir}/${id}.json" 2>/dev/null &
    pids+=($!)
  done
  for pid in "${pids[@]}"; do
    wait "$pid" 2>/dev/null || true
  done

  # Calculate coding score for each model
  local results=()
  for id in $model_ids; do
    local file="${tmpdir}/${id}.json"
    [[ -s "$file" ]] || continue

    local name axes
    name=$(printf '%s\n' "$dashboard" | jq -r \
      --arg id "$id" '.data.modelScores[] | select(.id == $id) | .name')
    axes=$(jq -r '.data[0].axes | [.correctness, .complexity, .codeQuality, .efficiency, .stability, .edgeCases, .debugging, .format, .safety] | @tsv' "$file" 2>/dev/null) || continue
    [[ -z "$axes" ]] && continue

    local corr cmplx cq eff stab edge dbg fmt safe
    read -r corr cmplx cq eff stab edge dbg fmt safe <<<"$axes"

    local score
    score=$(calc_coding_score "$corr" "$cmplx" "$cq" "$eff" "$stab" "$edge" "$dbg" "$fmt" "$safe")

    results+=("${score}|${name}|${corr}|${cmplx}|${cq}")
  done

  rm -rf "$tmpdir"

  # Sort by score descending
  printf '%s\n' "${results[@]}" | sort -t'|' -k1 -rn
}

# ── Fetch Data ──────────────────────────────────────
fetch_data() {
  local url="$1"
  local response
  response=$(curl -sf --max-time 10 "$url" 2>/dev/null)
  if [[ -z "$response" ]]; then
    spinner_stop
    printf '%s\n' "  ${RED}${SYM_CROSS} Failed to fetch data from API${RST}"
    exit 1
  fi
  printf '%s\n' "$response"
}

# ── JSON Output ─────────────────────────────────────
output_json() {
  local dashboard global_index
  dashboard=$(fetch_data "$DASHBOARD_URL")
  global_index=$(fetch_data "$GLOBAL_INDEX_URL")

  local now
  now=$(date +"%Y-%m-%d %H:%M")

  local reco
  reco=$(echo "$dashboard" | jq '.data.recommendations')

  # Calculate best coder
  local coding_scores
  coding_scores=$(fetch_coding_scores "$dashboard")
  local best_coder_json='null'
  if [[ -n "$coding_scores" ]]; then
    local top_line
    top_line=$(head -1 <<<"$coding_scores")
    local cscore cname corr cmplx cq
    IFS='|' read -r cscore cname corr cmplx cq <<<"$top_line"
    best_coder_json=$(jq -n \
      --arg name "$cname" \
      --argjson score "$cscore" \
      --argjson correctness "$(awk -v v="$corr" 'BEGIN { printf "%.0f", v * 100 }')" \
      --argjson complexity "$(awk -v v="$cmplx" 'BEGIN { printf "%.0f", v * 100 }')" \
      --argjson codeQuality "$(awk -v v="$cq" 'BEGIN { printf "%.0f", v * 100 }')" \
      '{name: $name, score: $score, correctness: $correctness, complexity: $complexity, codeQuality: $codeQuality}')
  fi

  # Build the entire JSON in a single jq call
  jq -n \
    --arg version "$VERSION" \
    --arg timestamp "$now" \
    --arg provider "$PROVIDER" \
    --arg model_pattern "$MODEL_NAME_PATTERN" \
    --argjson global_index "$global_index" \
    --argjson dashboard "$dashboard" \
    --argjson reco "$reco" \
    --argjson best_coder "$best_coder_json" \
    '
    {
      version: $version,
      timestamp: $timestamp,
      provider: $provider,
      globalIndex: {
        score: $global_index.data.current.globalScore,
        trend: $global_index.data.trend,
        performingWell: $global_index.data.performingWell,
        totalModels: $global_index.data.totalModels
      },

      rankings: [
        $dashboard.data.modelScores | to_entries[] |
        select(.value.provider == $provider) |
        {
          rank: (.key + 1),
          name: .value.name,
          score: .value.currentScore,
          status: (
            if .value.status == "good" then "stable"
            elif .value.status == "warning" then "volatile"
            else .value.status
            end
          )
        }
      ],

      bestCoder: $best_coder,

      bestFor: {
        code: (if $reco.bestForCode.vendor == $provider
          then {name: $reco.bestForCode.name, score: $reco.bestForCode.score}
          else null end),
        reliable: (if $reco.mostReliable.vendor == $provider
          then {name: $reco.mostReliable.name, score: $reco.mostReliable.score}
          else null end),
        fastest: (if $reco.fastestResponse.vendor == $provider
          then {name: $reco.fastestResponse.name, score: $reco.fastestResponse.score}
          else null end),
        value: (if ($reco.bestValue // {}).vendor == $provider
          then {name: $reco.bestValue.name, score: $reco.bestValue.score}
          else null end)
      },

      alerts: {
        avoid: [
          ($reco.avoidNow // [])[] |
          select(.vendor == $provider or .provider == $provider) |
          .name
        ],
        degradations: [
          $dashboard.data.degradations[] |
          select(.provider == $provider) |
          {
            model: .modelName,
            severity: .severity,
            type: .type,
            message: .message
          }
        ]
      },

      providerTrust: (
        [$dashboard.data.providerReliability[] | select(.provider == $provider)] |
        if length > 0 then
          .[0] | {
            score: .trustScore,
            trend: .trend,
            incidentsPerMonth: .incidentsPerMonth
          }
        else null end
      ),

      driftIncidents: [
        ($dashboard.data.driftIncidents // []) |
        [.[] | select(.provider == $provider or (.modelName | test($model_pattern; "i")))] |
        group_by(.modelName)[] |
        {
          model: .[0].modelName,
          severity: .[0].severity,
          count: length
        }
      ]
    }
    '
}

# ── Render ─────────────────────────────────────────
render() {
  local dashboard="$1" global_index="$2" last_updated="$3"
  local prev_ranks="${4:-}"

  # ── Extract all global index data in one call ───
  local g_score g_trend g_performing g_total
  read -r g_score g_trend g_performing g_total < <(
    printf '%s\n' "$global_index" | jq -r '[.data.current.globalScore, .data.trend, .data.performingWell, .data.totalModels] | @tsv'
  )

  # ── Extract all dashboard data in one call ──────
  local d
  d=$(printf '%s\n' "$dashboard" | jq --arg provider "$PROVIDER" --arg model_pattern "$MODEL_NAME_PATTERN" '
    (.data.modelScores | to_entries | [.[] | select(.value.provider == $provider)]) as $models |
    (.data.recommendations) as $reco |
    {
      goodModels: ([.data.modelScores[] | select(.status == "good") | .name] | join(", ")),
      models: [$models[] | {rank: (.key + 1), name: .value.name, score: .value.currentScore, status: .value.status}],
      modelCount: ($models | length),
      maxNameLen: ([$models[].value.name | length] | max // 0),
      bestFor: [
        (if $reco.bestForCode.vendor == $provider
         then {label: "BEST FOR CODE", pad: 5, name: $reco.bestForCode.name, score: $reco.bestForCode.score} else empty end),
        (if $reco.mostReliable.vendor == $provider
         then {label: "MOST RELIABLE", pad: 5, name: $reco.mostReliable.name, score: $reco.mostReliable.score} else empty end),
        (if $reco.fastestResponse.vendor == $provider
         then {label: "FASTEST RESPONSE", pad: 2, name: $reco.fastestResponse.name, score: $reco.fastestResponse.score} else empty end),
        (if ($reco.bestValue // {}).vendor == $provider
         then {label: "BEST VALUE", pad: 8, name: $reco.bestValue.name, score: $reco.bestValue.score} else empty end)
      ],
      avoidNow: [($reco.avoidNow // [])[] | select(.vendor == $provider or .provider == $provider) | .name],
      degradations: [.data.degradations[] | select(.provider == $provider) | {name: .modelName, severity, type, message}],
      providerTrust: (
        [.data.providerReliability[] | select(.provider == $provider)] |
        if length > 0 then .[0] | {score: .trustScore, trend, incidents: .incidentsPerMonth}
        else null end
      ),
      driftIncidents: [
        (.data.driftIncidents // []) |
        [.[] | select(.provider == $provider or (.modelName | test($model_pattern; "i")))] |
        group_by(.modelName)[] |
        {name: .[0].modelName, severity: (.[0].severity // "unknown"), count: length}
      ]
    }
  ')

  # ── Read all scalar fields from extracted data ──
  local model_count max_name_len best_count avoid_count deg_count drift_count
  read -r model_count max_name_len best_count avoid_count deg_count drift_count < <(
    printf '%s\n' "$d" | jq -r '[.modelCount, .maxNameLen, (.bestFor | length), (.avoidNow | length), (.degradations | length), (.driftIncidents | length)] | @tsv'
  )
  local good_models
  good_models=$(printf '%s\n' "$d" | jq -r '.goodModels')

  # ── Header ──────────────────────────────────────
  printf "\n"
  printf '%s\n' "  ${BOLD}${CYAN}${SYM_DIAMOND} AST${RST}  ${DIM}v${VERSION} ${GRAY}${SYM_BULLET} ${last_updated}${RST}"
  printf "\n"

  # ── Global Index ────────────────────────────────
  local trend_color
  trend_color=$(status_color "$g_trend")

  box_top "Global AI Index"
  dot_row "Score" "${BOLD}${trend_color}${g_score}${RST}/100 ${trend_color}$(status_label "$g_trend")${RST}"
  dot_row "Performing well" "${BOLD}${g_performing}${RST}/${g_total}"
  if [[ -n "$good_models" ]]; then
    local max_len=44
    if ((${#good_models} > max_len)); then
      good_models="${good_models:0:$((max_len - 3))}..."
    fi
    box_row "  ${GREEN}${SYM_ARROW}${RST} ${DIM}${good_models}${RST}"
  fi
  box_bottom
  printf "\n"

  # ── Model Rankings ───────────────────────────────
  box_top "${PROVIDER_LABEL} Rankings"
  if ((model_count == 0)); then
    box_empty "No ${PROVIDER_LABEL} models found in rankings"
  else
    printf '%s\n' "$d" | jq -r '.models[] | "\(.rank)|\(.name)|\(.score)|\(.status)"' | while IFS='|' read -r rank name score status; do
      local sc
      sc=$(status_color "$status")
      local sl
      sl=$(status_label "$status")
      # Rank change indicator — fixed 4-char column (watch mode only)
      local change_col="    "
      if [[ -n "$prev_ranks" ]]; then
        local prev_rank
        prev_rank=$(printf '%s\n' "$prev_ranks" | jq -r --arg n "$name" '.[$n] // empty')
        if [[ -n "$prev_rank" ]] && ((prev_rank != rank)); then
          local arrow_text
          if ((rank < prev_rank)); then
            arrow_text="${GREEN}${SYM_UP}${prev_rank}${RST}"
          else
            arrow_text="${RED}${SYM_DOWN}${prev_rank}${RST}"
          fi
          # Pad visible chars to 4: arrow(1) + digits + trailing spaces
          local visible_len=$((1 + ${#prev_rank}))
          local pad=$((4 - visible_len))
          change_col="${arrow_text}$(printf '%*s' "$pad" '')"
        fi
      fi
      # Pad rank, name, score for alignment
      local rank_str
      rank_str=$(printf '#%-2s' "$rank")
      local name_str
      name_str=$(printf "%-${max_name_len}s" "$name")
      local score_str
      score_str=$(printf '%-3s' "$score")
      local sym
      case "$status" in
      good | stable) sym="$SYM_CHECK" ;;
      volatile | warning) sym="$SYM_WARN" ;;
      *) sym="$SYM_CROSS" ;;
      esac
      box_row "${BOLD}${WHITE}${rank_str}${RST} ${change_col}${name_str} ${BOLD}${score_str}${RST} ${sc}${sym} ${sl}${RST}"
    done
  fi
  box_bottom
  printf "\n"

  # ── Best For Categories ─────────────────────────
  box_top "Best For Categories"
  if ((best_count == 0)); then
    box_empty "No ${PROVIDER_LABEL} model in any best-for category"
  else
    printf '%s\n' "$d" | jq -r '.bestFor[] | "\(.label)|\(.pad)|\(.name)|\(.score)"' | while IFS='|' read -r label pad_len name score; do
      local pad
      pad=$(printf '%*s' "$pad_len" '')
      box_row "${GREEN}${SYM_CHECK} ${label}${RST}${pad}${name} (${BOLD}${score}${RST})"
    done
  fi
  box_bottom
  printf "\n"

  # ── Best Coder (provider) ────────────────────────
  box_top "Best Coder (${PROVIDER_LABEL})"
  local coding_scores
  coding_scores=$(fetch_coding_scores "$dashboard")
  if [[ -z "$coding_scores" ]]; then
    box_empty "Could not calculate coding scores"
  else
    local top_line
    top_line=$(head -1 <<<"$coding_scores")
    local cscore name corr cmplx cq
    IFS='|' read -r cscore name corr cmplx cq <<<"$top_line"
    local corr_pct cmplx_pct cq_pct
    corr_pct=$(awk -v v="$corr" 'BEGIN { printf "%d", v * 100 }')
    cmplx_pct=$(awk -v v="$cmplx" 'BEGIN { printf "%d", v * 100 }')
    cq_pct=$(awk -v v="$cq" 'BEGIN { printf "%d", v * 100 }')
    box_row "${GREEN}${SYM_CHECK}${RST} ${name} ${BOLD}${cscore}${RST}"
    box_row "  ${DIM}Correctness ${corr_pct}%  Complexity ${cmplx_pct}%  Quality ${cq_pct}%${RST}"
  fi
  box_bottom
  printf "\n"

  # ── Alerts (Unreliable + Degradations) ──────────
  box_top "Alerts"
  if ((avoid_count == 0)) && ((deg_count == 0)); then
    box_row "${GREEN}${SYM_CHECK} No active alerts for ${PROVIDER_LABEL} models${RST}"
  else
    if ((avoid_count > 0)); then
      printf '%s\n' "$d" | jq -r '.avoidNow[]' | while read -r name; do
        box_row "${RED}${SYM_CROSS} AVOID${RST}  ${name}"
      done
    fi

    if ((deg_count > 0)); then
      printf '%s\n' "$d" | jq -r '.degradations[] | "\(.name)|\(.severity)|\(.type)|\(.message)"' | while IFS='|' read -r name severity dtype message; do
        # Clean message: strip emoji, leading label, and truncate
        local clean_msg
        clean_msg=$(printf '%s' "$message" | LC_ALL=C tr -cd '\11\12\40-\176' | sed 's/^ *//; s/^[A-Z_ ]*: //')
        if ((${#clean_msg} > BOX_WIDTH - 6)); then
          clean_msg="${clean_msg:0:$((BOX_WIDTH - 9))}..."
        fi
        local sc
        sc=$(status_color "$severity")
        local label
        case "$dtype" in
        unstable_performance) label="UNSTABLE" ;;
        critical_failure) label="CRITICAL" ;;
        performance_variance) label="VARIANCE" ;;
        poor_performance) label="POOR" ;;
        *) label=$(printf '%s' "$severity" | tr '[:lower:]' '[:upper:]') ;;
        esac
        box_row "${sc}${SYM_WARN} ${label}${RST}  ${name}"
        box_row "  ${DIM}${clean_msg}${RST}"
      done
    fi
  fi
  box_bottom
  printf "\n"

  # ── Provider Trust ──────────────────────────────
  local trust_tsv
  trust_tsv=$(printf '%s\n' "$d" | jq -r 'if .providerTrust then [.providerTrust.score, .providerTrust.trend, .providerTrust.incidents] | @tsv else empty end')
  if [[ -n "$trust_tsv" ]]; then
    local trust_score trust_trend incidents
    read -r trust_score trust_trend incidents <<<"$trust_tsv"
    local tc
    tc=$(status_color "$trust_trend")

    box_top "${PROVIDER_LABEL} Provider Trust"
    dot_row "Trust Score" "${BOLD}${tc}${trust_score}${RST}/100"
    dot_row "Trend" "${tc}${trust_trend}${RST}"
    dot_row "Incidents/month" "${YELLOW}${incidents}${RST}"
    box_bottom
    printf "\n"
  fi

  # ── Drift Incidents ─────────────────────────────
  if ((drift_count > 0)); then
    box_top "Drift Incidents"
    printf '%s\n' "$d" | jq -r '.driftIncidents[] | "\(.name)|\(.severity)|\(.count)"' | while IFS='|' read -r name severity count; do
      local sc
      sc=$(status_color "$severity")
      local count_str=""
      if ((count > 1)); then
        count_str=" ${DIM}(${count}x)${RST}"
      fi
      box_row "${sc}${SYM_WARN}${RST} ${name}${count_str}"
    done
    box_bottom
    printf "\n"
  fi
}

# ── Main ────────────────────────────────────────────
main() {
  local json_mode=false
  local watch_mode=false
  local watch_interval=60
  local provider_mode=claude
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --version)
      printf '%s\n' "${VERSION}"
      exit 0
      ;;
    --help)
      printf '%s\n' "  ${BOLD}${CYAN}${SYM_DIAMOND} AST${RST}  ${DIM}v${VERSION}${RST} — AI Stupidity Tracker"
      printf '\n'
      printf '%s\n' "  ${BOLD}Usage:${RST}  ast [--claude|--openai] [options]"
      printf '\n'
      printf '%s\n' "  ${BOLD}Provider:${RST}"
      printf '%s\n' "    --claude            Track Claude/Anthropic models (default)"
      printf '%s\n' "    --openai            Track OpenAI models"
      printf '\n'
      printf '%s\n' "  ${BOLD}Options:${RST}"
      printf '%s\n' "    --json              Machine-readable JSON output"
      printf '%s\n' "    --watch[=SECONDS]   Live dashboard, refreshes every N seconds (default: 60)"
      printf '%s\n' "    --version           Show version number
    --help              Show this help message"
      printf '\n'
      printf '%s\n' "  ${BOLD}Environment:${RST}"
      printf '%s\n' "    NO_COLOR=1          Disable colors and box-drawing right borders"
      exit 0
      ;;
    --json) json_mode=true ;;
    --claude) provider_mode=claude ;;
    --openai) provider_mode=openai ;;
    --watch=*)
      watch_mode=true
      watch_interval="${1#--watch=}"
      if ! [[ "$watch_interval" =~ ^[0-9]+$ ]]; then
        printf "  ${RED}${SYM_CROSS} Invalid watch interval: %s (must be a number)${RST}\n" "$watch_interval"
        exit 1
      fi
      ;;
    --watch)
      watch_mode=true
      if [[ -n "${2:-}" && "$2" =~ ^[0-9]+$ ]]; then
        watch_interval="$2"
        shift
      fi
      ;;
    -*)
      printf "  ${RED}${SYM_CROSS} Unknown option: %s${RST}\n" "$1"
      printf "  Usage: ast [--claude|--openai] [--json] [--watch[=SECONDS]] [--help]\n"
      exit 1
      ;;
    *)
      printf "  ${RED}${SYM_CROSS} Unexpected argument: %s${RST}\n" "$1"
      printf "  Usage: ast [--claude|--openai] [--json] [--watch[=SECONDS]] [--help]\n"
      exit 1
      ;;
    esac
    shift
  done

  # Provider configuration
  case "$provider_mode" in
  claude)
    PROVIDER="anthropic"
    PROVIDER_LABEL="Claude"
    MODEL_NAME_PATTERN="claude"
    ;;
  openai)
    PROVIDER="openai"
    PROVIDER_LABEL="OpenAI"
    MODEL_NAME_PATTERN="gpt"
    ;;
  esac

  if [[ "$json_mode" == true ]]; then
    output_json
    return
  fi

  if [[ "$watch_mode" == true ]]; then
    watch_loop "$watch_interval"
    return
  fi

  # One-shot mode
  spinner_start "Fetching ${PROVIDER_LABEL} status"
  local dashboard global_index
  dashboard=$(fetch_data "$DASHBOARD_URL")
  global_index=$(fetch_data "$GLOBAL_INDEX_URL")
  spinner_stop

  local now
  now=$(date +"%Y-%m-%d %H:%M")

  render "$dashboard" "$global_index" "$now"
}

# ── Watch Loop ─────────────────────────────────────
watch_loop() {
  local WATCH_INTERVAL="${1:-60}"
  local first_run=true
  local prev_ranks="{}"

  trap 'exit 0' INT TERM

  while true; do
    if [[ "$first_run" == true ]]; then
      # First run: show spinner since there's nothing on screen yet
      spinner_start "Fetching ${PROVIDER_LABEL} status"
    fi

    local dashboard global_index
    dashboard=$(fetch_data "$DASHBOARD_URL")
    global_index=$(fetch_data "$GLOBAL_INDEX_URL")

    if [[ "$first_run" == true ]]; then
      spinner_stop
      first_run=false
    fi

    local now
    now=$(date +"%Y-%m-%d %H:%M")

    # Extract current rankings as {name: rank} map
    local curr_ranks
    curr_ranks=$(echo "$dashboard" | jq --arg provider "$PROVIDER" '
      [.data.modelScores | to_entries[] |
       select(.value.provider == $provider)] |
      map({(.value.name): (.key + 1)}) | add // {}
    ')

    # Capture output, then clear and print in one shot to reduce flicker
    local output
    output=$(render "$dashboard" "$global_index" "$now" "$prev_ranks")
    printf '\033[2J\033[H%s\n' "$output"

    local next_update
    next_update=$(date -d "+${WATCH_INTERVAL} seconds" +"%Y-%m-%d %H:%M" 2>/dev/null || date -v+"${WATCH_INTERVAL}S" +"%Y-%m-%d %H:%M")
    printf '%s\n' "  ${DIM}Next update ${next_update} ${GRAY}${SYM_BULLET}${RST} ${DIM}Ctrl+C to exit${RST}"

    prev_ranks="$curr_ranks"

    sleep "$WATCH_INTERVAL"
  done
}

main "$@"
